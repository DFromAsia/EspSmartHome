void connectWiFi() {
  centerText("Connecting WiFi", 1);
  WiFi.disconnect();
  WiFi.begin(ssid, password);
  
  unsigned long connectStart = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - connectStart < 15000) { // 15s timeout
    // Allow long-press to interrupt connection attempt
    if (digitalRead(BUTTON_PIN) == LOW) {
        unsigned long pressTime = millis();
        while(digitalRead(BUTTON_PIN) == LOW); // wait for release
        if (millis() - pressTime > 3000) {
            startOfflineMusicMode();
            return; // Exit connection attempt and go straight to music mode
        }
    }

    setRGB(0,0,120);
    delay(100);
    setRGB(0,0,0);
    delay(100);
    Serial.print(".");
  }

  if (WiFi.status() != WL_CONNECTED) {
    centerText("Scanning Open", 1);
    int n = WiFi.scanNetworks();
    for (int i = 0; i < n; ++i) {
      if (WiFi.encryptionType(i) == WIFI_AUTH_OPEN) {
        String openSSID = WiFi.SSID(i);
        centerText("Connecting:\n" + openSSID, 1);
        WiFi.begin(openSSID.c_str());
        unsigned long openConnectStart = millis();
        while (WiFi.status() != WL_CONNECTED && millis() - openConnectStart < 10000) {
          setRGB(120,0,120);
          delay(100);
          setRGB(0,0,0);
          delay(100);
        }
        if (WiFi.status() == WL_CONNECTED) {
          break;
        }
      }
    }
  }

  if (WiFi.status() == WL_CONNECTED && !offlineMusicMode) {
    wifiConnected = true;
    centerText("WiFi Connected", 1);
    delay(1000);
    
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
    struct tm timeinfo;
    if(getLocalTime(&timeinfo, 5000)) {
      savedEpoch = time(nullptr);
      savedMillis = millis();
      ntpSynced = true;
    }
  } else if (!offlineMusicMode) {
    centerText("WiFi Failed", 1);
    delay(2000);
  }
}

// =====================================================
// WIFI CHECK (SILENT 10s BACKGROUND RECONNECT)
// =====================================================

void checkWiFi() {
  if (offlineMusicMode) return;
  if (WiFi.status() == WL_CONNECTED) {
    if (!wifiConnected) {
      wifiConnected = true;
      configTime(gmtOffset_sec, daylightOffset_sec, ntpServer); // Re-initialize SNTP on reconnect
    }
    return;
  }

  wifiConnected = false;
  ntpSynced = false; // Connection is down, so we are no longer NTP synced
  
  // Silently try to reconnect every 10 seconds without blocking the UI
  if (millis() - lastReconnectTry > 10000) {
    lastReconnectTry = millis();
    WiFi.disconnect();
    WiFi.begin(ssid, password);
  }
}


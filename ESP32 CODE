String wrapText(String text, int maxChars) {
  String result = "";
  String currentLine = "";
  String currentWord = "";

  for (int i = 0; i < text.length(); i++) {
    char c = text[i];
    if (c == ' ' || c == '\n') {
      if (currentWord.length() > 0) {
        if (currentLine.length() + currentWord.length() + (currentLine.length() > 0 ? 1 : 0) > maxChars) {
          if (result.length() > 0) result += "\n";
          result += currentLine;
          currentLine = currentWord;
        } else {
          if (currentLine.length() > 0) currentLine += " ";
          currentLine += currentWord;
        }
        currentWord = "";
      }
      
      if (c == '\n') {
        if (result.length() > 0) result += "\n";
        result += currentLine;
        currentLine = "";
      }
    } else {
      currentWord += c;
      if (currentWord.length() >= maxChars) {
        if (currentLine.length() > 0) {
          if (result.length() > 0) result += "\n";
          result += currentLine;
          currentLine = "";
        }
        if (result.length() > 0) result += "\n";
        result += currentWord;
        currentWord = "";
      }
    }
  }
  
  if (currentWord.length() > 0) {
    if (currentLine.length() + currentWord.length() + (currentLine.length() > 0 ? 1 : 0) > maxChars) {
      if (currentLine.length() > 0) {
        if (result.length() > 0) result += "\n";
        result += currentLine;
      }
      currentLine = currentWord;
    } else {
      if (currentLine.length() > 0) currentLine += " ";
      currentLine += currentWord;
    }
  }
  
  if (currentLine.length() > 0) {
    if (result.length() > 0) result += "\n";
    result += currentLine;
  }
  return result;
}

void centerText(String text, int size) {
  display.clearDisplay();
  display.setTextSize(size);
  display.setTextWrap(false);

  int numLines = 1;
  for (int i = 0; i < text.length(); i++) {
    if (text[i] == '\n') numLines++;
  }

  int charHeight = 8 * size; 
  int totalHeight = numLines * charHeight;
  int startY = (64 - totalHeight) / 2;

  int startIndex = 0;
  for (int i = 0; i < numLines; i++) {
    int endIndex = text.indexOf('\n', startIndex);
    if (endIndex == -1) endIndex = text.length();
    
    String line = text.substring(startIndex, endIndex);
    
    int16_t x1, y1;
    uint16_t w, h;
    display.getTextBounds(line.c_str(), 0, 0, &x1, &y1, &w, &h);
    
    int x = (128 - w) / 2;
    if (x < 0) x = 0;
    int y = startY + (i * charHeight);
    
    display.setCursor(x, y);
    display.println(line);
    
    startIndex = endIndex + 1;
  }
  display.display();
}

// =====================================================
// RGB (UPDATED FOR ESP32 CORE v3.x)
// =====================================================

void setRGB(int r, int g, int b) {
  r = (r * rgbBrightness) / 255;
  g = (g * rgbBrightness) / 255;
  b = (b * rgbBrightness) / 255;

  ledcWrite(RED_PIN, r);
  ledcWrite(GREEN_PIN, g);
  ledcWrite(BLUE_PIN, b);
}

// =====================================================
// RGB CYCLE
// =====================================================

void updateRGBCycle() {
  float t = (millis() % 30000) / 30000.0;
  float r, g, b;

  if (t < 0.333) {
    float p = t / 0.333;
    r = 255 * (1 - p);
    g = 255 * p;
    b = 0;
  } else if (t < 0.666) {
    float p = (t - 0.333) / 0.333;
    r = 0;
    g = 255 * (1 - p);
    b = 255 * p;
  } else {
    float p = (t - 0.666) / 0.334;
    r = 255 * p;
    g = 0;
    b = 255 * (1 - p);
  }

  setRGB(r, g, b);
}


// =====================================================
void drawOfflineMusicScreen() {
  if (millis() - lastInteractionTime > 300000 && musicPlayerActive) {
    display.clearDisplay();
    display.display();
    lastDisplayedLyric = ""; // Reset to force redraw on wake
    return;
  }

  if (musicPlayerActive == lastMusicPlayerActive && currentLyricLine == lastDisplayedLyric) {
    return; // Optimization: only redraw when needed
  }

  lastDisplayedLyric = currentLyricLine;
  lastMusicPlayerActive = musicPlayerActive;

  display.clearDisplay();
  display.setTextWrap(true);
  display.setCursor(0, 0);

  if (!musicPlayerActive) {
    display.setTextSize(1);
    display.println("SSID: esp32");
    display.println("PASS: 12345678");
    display.println("");
    display.println("IP: " + WiFi.softAPIP().toString());
    display.println("");
    display.println("Open website and");
    display.println("press ENTER...");
            display.display();
  } else {
            String wrappedLyrics = wrapText(currentLyricLine, 21);
            centerText(wrappedLyrics, 1);
  }
}

// =====================================================
// LOOP (RUNS ON CORE 1)
// =====================================================

void loop() {
  handleButton();

  if (offlineMusicMode) {
    server.handleClient();
    if (millis() - lastClockDraw > 100) { // Update OLED at 10fps
      lastClockDraw = millis();
      drawOfflineMusicScreen();
    }
    return; // Skip all normal operations
  }

  checkWiFi();

  // =====================================================
  // DHT SENSOR READ (Non-Blocking)
  // =====================================================
  if (displayType == "info") {
    if (millis() - lastDHTRead > 2000) {
      lastDHTRead = millis();
      float t = dht.readTemperature();
      float h = dht.readHumidity();
      if (!isnan(t)) roomTemp = t;
      if (!isnan(h)) roomHum = h;
    }
  }

  // The rest of the loop is for normal clock operation

  if (isTimerRinging || isAlarmRinging || newMessageAvailable) {
    lastInteractionTime = millis(); // Wake up OLED instantly
  }

  bool systemAsleep = false;
  if (!offlineMusicMode && (millis() - lastInteractionTime > 600000)) { // 10 mins
    systemAsleep = true;
  }

  // RINGING ENGINE (NON-BLOCKING)
  if (isTimerRinging || isAlarmRinging) {
    unsigned long duration = isTimerRinging ? 5000 : 10000;
    unsigned long startT = isTimerRinging ? timerRingStart : alarmRingStart;

    if (millis() - startT < duration) {
      if (millis() - lastRingToggle > 200) {
        lastRingToggle = millis();
        ringToggleState = !ringToggleState;
        if (ringToggleState) {
          setRGB(255, 0, 0);
          tone(BUZZER_PIN, 2000);
          if (isTimerRinging) centerText("DONE", 3);
          else centerText(alarmMessage, 2);
        } else {
          setRGB(0, 0, 0);
          noTone(BUZZER_PIN);
          display.clearDisplay();
          display.display();
        }
      }
      return; // Suspend normal clock execution while UI flashes 
    } else {
      isTimerRinging = false;
      isAlarmRinging = false;
      setRGB(0, 0, 0);
      noTone(BUZZER_PIN);
    }
  }

  // RGB
  if (systemAsleep) {
    setRGB(0, 0, 0);
  } else if (displayType == "info") {
    float clampedHum = roomHum;
    if (clampedHum < 50.0) clampedHum = 50.0;
    if (clampedHum > 95.0) clampedHum = 95.0;
    
    float ratio = (clampedHum - 50.0) / 45.0;
    int r = (1.0 - ratio) * 255;
    int b = ratio * 255;
    setRGB(r, 0, b);
  } else if (rgbMode == "cycle") {
    updateRGBCycle();
  } else if (rgbMode == "solid") {
    setRGB(solidR, solidG, solidB);
  } else {
    setRGB(0,0,0);
  }

  // MESSAGE
  if (newMessageAvailable && !timerRunning && !alarmTriggered) {
    newMessageAvailable = false;
    messageDisplaying = true;
    messageStartTime = millis();

    if (wifiConnected) {
      HTTPClient msgHttp;
      msgHttp.begin(secureClientCore1, "FIREBASE_DATABASE_URL_HERE/message/new.json");
      msgHttp.addHeader("Content-Type", "application/json");
      msgHttp.PUT("false");
      msgHttp.end();

      lastFirebaseRead = millis(); 
    }
  }

  if (messageDisplaying && !timerRunning && !alarmTriggered) {
    if (millis() - messageStartTime < 15000) {
      int len = currentMessage.length();
      int textSize = 1;
      if (len <= 14) textSize = 3;
      else if (len <= 40) textSize = 2;
      
      centerText(currentMessage, textSize);
      return; // Pause regular clock drawing while displaying message
    } else {
      messageDisplaying = false;
      display.clearDisplay();
    }
  }

  // TIMER
  if (timerRunning) {
    
    while (millis() - lastTimerTick >= 1000) {
      lastTimerTick += 1000; 
      timerSeconds--;

      if (timerSeconds <= 0) {
          timerRunning = false;
          isTimerRinging = true;
          timerRingStart = millis();
        
        if (wifiConnected) {
          HTTPClient timerHttp;
          timerHttp.begin(secureClientCore1, "FIREBASE_DATABASE_URL_HERE/timer/running.json");
          timerHttp.addHeader("Content-Type", "application/json");
          timerHttp.PUT("false");
          timerHttp.end();
          
          lastFirebaseRead = millis();
        }
        break; 
      }
    }

    if (timerRunning) {
      centerText(String(timerSeconds), 4);
      delay(50);
      return;
    }
  }

  // TIME
  time_t now = getCurrentTime();
  struct tm* timeinfo = localtime(&now);
  char currentTime[10];
  
  strftime(currentTime, sizeof(currentTime), "%H:%M", timeinfo);
  
  // ALARM
  if (alarmEnabled && String(currentTime) == alarmTime && !alarmTriggered && timeinfo->tm_sec == 0) {
    alarmTriggered = true;
    isAlarmRinging = true;
    alarmRingStart = millis();
  }

  if (timeinfo->tm_sec > 5) {
    alarmTriggered = false;
  }

  // HOURLY BEEP
  if (timeinfo->tm_min == 0 && timeinfo->tm_sec == 0 && millis() - lastHourlyBeep > 60000) {
    lastHourlyBeep = millis();
    tone(BUZZER_PIN, 1500);
    delay(1000);
    noTone(BUZZER_PIN);
  }

  // CLOCK
  if (millis() - lastClockDraw > 1000) {
    lastClockDraw = millis();

    if (systemAsleep) {
      display.clearDisplay();
      display.display();
    } else if (displayType == "analog") {
      drawAnalogClock();
    } else if (displayType == "digital") {
      drawDigitalClock();
    } else {
      drawInfoDisplay();
    }
  }
}

void handleButton() {
  bool currentButtonState = digitalRead(BUTTON_PIN);
  if (lastButtonState == HIGH && currentButtonState == LOW) {
    buttonPressTime = millis();
    buttonPressed = true;
    buttonHandled = false;
    lastInteractionTime = millis(); // Wake up OLED
  }

  // LONG PRESS (OFFLINE MUSIC MODE TOGGLE)
  if (buttonPressed && currentButtonState == LOW && !buttonHandled) {
    if (millis() - buttonPressTime > 3000) {
      buttonHandled = true;
      if (!offlineMusicMode) {
        startOfflineMusicMode();
      } else {
        stopOfflineMusicMode();
      }
    }
  }

  // SHORT PRESS (CONTEXT ACTIONS)
  if (buttonPressed && currentButtonState == HIGH) {
    buttonPressed = false;
    if (!buttonHandled && (millis() - buttonPressTime > 50)) { // 50ms Debounce
      if (offlineMusicMode) return; // Short press does nothing in music mode

      // PRIORITY 1: The Silencer
      if (isTimerRinging || isAlarmRinging) {
        isTimerRinging = false;
        isAlarmRinging = false;
        setRGB(0,0,0);
        noTone(BUZZER_PIN);
        if (wifiConnected) {
          HTTPClient http;
          http.begin(secureClientCore1, "FIREBASE_DATABASE_URL_HERE/.json");
          http.addHeader("Content-Type", "application/json");
          http.PATCH("{\"timer/running\":false,\"alarm/enabled\":false}");
          http.end();
        }
      } else if (timerRunning) {
        timerRunning = false;
        if (wifiConnected) {
          HTTPClient http;
          http.begin(secureClientCore1, "FIREBASE_DATABASE_URL_HERE/timer/running.json");
          http.addHeader("Content-Type", "application/json");
          http.PUT("false");
          http.end();
        }
      }
      else {
        if (displayType == "analog") displayType = "digital";
        else if (displayType == "digital") displayType = "info";
        else displayType = "analog";

        if (wifiConnected) {
          HTTPClient http;
          http.begin(secureClientCore1, "FIREBASE_DATABASE_URL_HERE/display/type.json");
          http.addHeader("Content-Type", "application/json");
          http.PUT("\"" + displayType + "\"");
          http.end();
        }
      }
    }
  }
  lastButtonState = currentButtonState;
    }

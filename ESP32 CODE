void handleTimeSync() {
  lastInteractionTime = millis();
  if (server.hasArg("time")) {
    String timeStr = server.arg("time");
    long long ms = atoll(timeStr.c_str());
    savedEpoch = ms / 1000;
    savedMillis = millis();
  }
  server.send(200, "text/plain", "Time Synced");
}

void handleLyricSync() {
  lastInteractionTime = millis();
  if (server.hasArg("line")) {
    currentLyricLine = server.arg("line");
    currentLyricLine.replace("+", " ");
  }
  server.send(200, "text/plain", "OK");
}

void handleSongList() {
  File musicDir = SD.open("/music");
  if (!musicDir || !musicDir.isDirectory()) {
    server.send(500, "text/plain", "Failed to open /music directory");
    return;
  }

  String songsJson = "[";
  File file = musicDir.openNextFile();
  bool first = true;
  while (file) {
    if (String(file.name()).endsWith(".mp3")) {
      if (!first) songsJson += ",";
      songsJson += "\"" + String(file.name()) + "\"";
      first = false;
    }
    file.close();
    file = musicDir.openNextFile();
  }
  songsJson += "]";
  musicDir.close();

  String favsJson = "[";
  File favFile = SD.open("/favorites.txt", FILE_READ);
  if (favFile) {
    first = true;
    while (favFile.available()) {
      String line = favFile.readStringUntil('\n');
      line.trim();
      if (line.length() > 0) {
        if (!first) favsJson += ",";
        favsJson += "\"" + line + "\"";
        first = false;
      }
    }
    favFile.close();
  }
  favsJson += "]";

  String json = "{\"songs\":" + songsJson + ",\"favorites\":" + favsJson + "}";
  server.send(200, "application/json", json);
}

void handleFav() {
  lastInteractionTime = millis();
  if (server.hasArg("add")) {
    String songToAdd = server.arg("add");
    
    bool exists = false;
    File checkFile = SD.open("/favorites.txt", FILE_READ);
    if (checkFile) {
      while (checkFile.available()) {
        String line = checkFile.readStringUntil('\n');
        line.trim();
        if (line == songToAdd) {
          exists = true;
          break;
        }
      }
      checkFile.close();
    }
    
    if (!exists) {
      File favFile = SD.open("/favorites.txt", FILE_APPEND);
      if (favFile) {
        favFile.println(songToAdd);
        favFile.close();
        server.send(200, "text/plain", "Added");
        return;
      }
      server.send(500, "text/plain", "Failed to open favorites file");
    } else {
      server.send(200, "text/plain", "Already exists");
    }
  } else {
    server.send(400, "text/plain", "Bad Request");
  }
}

void handleVisualizer() {
  lastInteractionTime = millis();
  if (server.hasArg("amp")) {
    int amp = server.arg("amp").toInt();
    int r = 0, g = 0, b = 0;
    if (amp > 10) { 
      r = map(amp, 0, 255, 0, 255);
      b = map(255 - amp, 0, 255, 0, 255);
      g = (amp > 150) ? map(amp, 150, 255, 0, 255) : 0;
    }
    setRGB(r, g, b);
  }
  server.send(200, "text/plain", "OK");
}

void handleFileStream() {
  String path = server.urlDecode(server.uri());
  if (path.endsWith("/")) {
    path += "index.html";
  }
  String contentType = "text/plain";
  if (path.endsWith(".mp3")) {
    contentType = "audio/mpeg";
  } else if (path.endsWith(".lrc")) {
    contentType = "text/plain";
  }

  if (SD.exists(path)) {
    File file = SD.open(path, FILE_READ);
    server.sendHeader("Accept-Ranges", "bytes");
    server.streamFile(file, contentType);
    file.close();
  } else {
    handleNotFound();
  }
}


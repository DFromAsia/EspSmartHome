// =====================================================
// ANALOG CLOCK
// =====================================================

void drawAnalogClock() {
  time_t now = getCurrentTime();
  struct tm* timeinfo = localtime(&now);

  int sec = timeinfo->tm_sec;
  int min = timeinfo->tm_min;
  int hour = timeinfo->tm_hour;

  if (hour > 12) hour -= 12;
  
  float secAngle = sec * 6;
  float minAngle = min * 6 + sec * 0.1;
  float hourAngle = hour * 30 + min * 0.5;

  display.clearDisplay();
  display.drawCircle(cx, cy, radius, SH110X_WHITE);
  
  for (int i = 0; i < 12; i++) {
    float angle = (i * 30 - 90) * PI / 180;
    int x1 = cx + cos(angle) * (radius - 2);
    int y1 = cy + sin(angle) * (radius - 2);
    int x2 = cx + cos(angle) * radius;
    int y2 = cy + sin(angle) * radius;
    display.drawLine(x1, y1, x2, y2, SH110X_WHITE);
  }

  float secRad = (secAngle - 90) * PI / 180;
  float minRad = (minAngle - 90) * PI / 180;
  float hourRad = (hourAngle - 90) * PI / 180;
  
  int sx = cx + cos(secRad) * (radius - 2);
  int sy = cy + sin(secRad) * (radius - 2);
  int mx = cx + cos(minRad) * (radius - 6);
  int my = cy + sin(minRad) * (radius - 6);
  int hx = cx + cos(hourRad) * (radius - 14);
  int hy = cy + sin(hourRad) * (radius - 14);
  
  display.drawLine(cx, cy, sx, sy, SH110X_WHITE);
  display.drawLine(cx, cy, mx, my, SH110X_WHITE);
  display.drawLine(cx, cy, hx, hy, SH110X_WHITE);
  display.fillCircle(cx, cy, 2, SH110X_WHITE);

  display.display();
}

// =====================================================
// FIREBASE
// =====================================================

void readFirebase() {
  HTTPClient http;
  http.begin(secureClientCore0, firebaseURL);
  int code = http.GET();

  if (code == 200) {
    String payload = http.getString();
    DynamicJsonDocument doc(8192);
    deserializeJson(doc, payload);

    // DISPLAY TYPE
    displayType = doc["display"]["type"] | "analog";

    // RGB
    rgbMode = doc["rgb"]["mode"] | "cycle";
    rgbBrightness = doc["rgb"]["brightness"] | 128;
    solidR = doc["rgb"]["r"] | 255;
    solidG = doc["rgb"]["g"] | 255;
    solidB = doc["rgb"]["b"] | 255;

    // MESSAGE 
    bool newMessage = doc["message"]["new"] | false;
    if (newMessage && !timerRunning && !alarmTriggered) {
      currentMessage = doc["message"]["text"] | "";
      newMessageAvailable = true;
    }

    // TIMER
    bool incomingTimer = doc["timer"]["running"] | false;
    int incomingSeconds = doc["timer"]["seconds"] | 0;
    
    if (incomingTimer && !timerRunning && incomingSeconds > 0) {
      timerRunning = true;
      timerSeconds = incomingSeconds;
      lastTimerTick = millis();
    }

    if (!incomingTimer && timerRunning) {
      timerRunning = false;
    }

    // ALARM
    alarmEnabled = doc["alarm"]["enabled"] | false;
    alarmTime = doc["alarm"]["time"] | "";
    alarmMessage = doc["alarm"]["message"] | "ALARM";
  }
  http.end();
}

// =====================================================
// HEARTBEAT
// =====================================================

void sendHeartbeat() {
  HTTPClient http;
  http.begin(secureClientCore0, "FIREBASE_DATABASE_URL_HERE/system/lastSeen.json");
  http.addHeader("Content-Type", "application/json");
  http.PUT(String(time(nullptr)));
  http.end();
}

// =====================================================
// DUAL-CORE NETWORK TASK (RUNS ON CORE 0)
// =====================================================

void firebaseTaskCode(void * parameter) {
  for(;;) {
    // This task is suspended entirely during offlineMusicMode

    // NTP Time Sync Logic: Always try to sync if we have WiFi but haven't synced yet.
    if (wifiConnected && !ntpSynced) {
      struct tm timeinfo;
      if(getLocalTime(&timeinfo, 5000)) { // Increased wait for successful sync
        savedEpoch = time(nullptr);
        savedMillis = millis();
        ntpSynced = true; // Success!
      }
    }

    if (wifiConnected && !timerRunning) {
      
      // Fast polling: Checks website every 1.5 seconds for instant response
      if (millis() - lastFirebaseRead > 5000) {
        lastFirebaseRead = millis();
        readFirebase();
      }

      // Heartbeat: Sends ONLINE status exactly every 5 mins (300,000 ms)
      if (millis() - lastHeartbeat > 300000) {
        lastHeartbeat = millis();
        sendHeartbeat();
      }

      // DHT Sensor Update: ONLY trigger when Clock Face is "info"
      if (displayType == "info" && (millis() - lastDHTFirebaseUpdate > 5000)) {
        lastDHTFirebaseUpdate = millis();
        HTTPClient dhtHttp;
        dhtHttp.begin(secureClientCore0, "FIREBASE_DATABASE_URL_HERE/dht.json");
        dhtHttp.addHeader("Content-Type", "application/json");
        String payload = "{\"temperature\":" + String(roomTemp, 1) + ",\"humidity\":" + String(roomHum, 1) + "}";
        dhtHttp.PATCH(payload);
        dhtHttp.end();
      }
    }
    
    // Crucial: Yields Core 0 to prevent the ESP32 Watchdog from crashing
    vTaskDelay(50 / portTICK_PERIOD_MS);
  }
}

// =====================================================
// SETUP 
// =====================================================

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);
  Wire.setClock(400000);
  
  display.begin(0x3C, true);
  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);

  // GPIO
  ledcAttach(RED_PIN, 5000, 8);
  ledcAttach(GREEN_PIN, 5000, 8);
  ledcAttach(BLUE_PIN, 5000, 8);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  dht.begin();

  secureClientCore0.setInsecure();
  secureClientCore1.setInsecure();

  // SD Card
  if(!SD.begin(SD_CS)){
    centerText("SD Card Error", 1);
    delay(3000);
  }

  // Connect to WiFi, but this can be interrupted by a long press
  // to enter offline music mode immediately.
  connectWiFi();

  // If we didn't enter offline mode during boot, start the network task on Core 0.
  if (!offlineMusicMode) {
    // Start the Dual-Core Magic
    xTaskCreatePinnedToCore(
      firebaseTaskCode,   /* Task function */
      "FirebaseTask",     /* Name of task */
      10000,              /* Stack size */
      NULL,               /* Task parameter */
      1,                  /* Priority */
      &firebaseTask,      /* Task handle */
      0                   /* Pin task to Core 0 */
    );
  }
}


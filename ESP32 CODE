time_t getCurrentTime() {
  time_t now = time(nullptr);
  if (now > 1600000000) { // If time is set by SNTP (year > 2020), use the system RTC directly
    return now;
  }
  return savedEpoch + ((millis() - savedMillis) / 1000); // Fallback for offline manual sync
}

